# Token de la plateforme Forgejo (compte bot/technique) — injecté dans RENOVATE_TOKEN.
# Doit avoir accès EN ÉCRITURE aux repos scannés (push des branches + ouverture des PRs).
# Forgejo : Settings → Applications → Generate New Token
#   scopes : repository (Read & Write), issue (Read & Write), user (Read)
RENOVATE_FORGEJO_TOKEN=change_me_forgejo_token

# Token github.com EN LECTURE SEULE — sert uniquement à interroger l'API github.com
# (versions des dépendances + changelogs/release notes des deps hébergées sur GitHub).
# Sans lui, Renovate tape l'API en anonyme et se fait rate-limiter (60 req/h → 403).
# PAT classic : scope public_repo (ou aucun scope) — JAMAIS de droit d'écriture ici.
RENOVATE_GITHUB_COM_TOKEN=change_me_github_readonly_token
