# PostgreSQL
PG_USER=authentik
PG_DB=authentik
PG_PASS=change_me_strong_password

# Authentik — clé secrète (générer avec: openssl rand -base64 60)
AUTHENTIK_SECRET_KEY=change_me_to_a_long_random_string

# SMTP — relais Postfix interne (stack messaging/postfix), joint via le réseau Docker
# partagé messaging_net. Le port 587 n'est PAS exposé sur l'hôte : on vise le conteneur
# par son nom. User SASL dédié authentik (doit exister dans SMTP_USER côté postfix).
MAILER_SMTP_ADDR=messaging_postfix_mail_sender
MAILER_SMTP_PORT=587
MAILER_USER=authentik-noreply@wittnerlab.com
MAILER_PASSWD=change_me_authentik_smtp_password
MAILER_FROM=authentik@wittnerlab.com
