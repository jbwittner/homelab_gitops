# Hostname FQDN du serveur SMTP (doit correspondre au certificat Let's Encrypt)
HOSTNAME=postfix.wittnerlab.com

# Domaines autorisés à envoyer du mail (séparés par des virgules)
ALLOWED_SENDER_DOMAINS=wittnerlab.com

# Authentification SASL — format: user:password (plusieurs users séparés par des espaces)
# Le 2e user (forgejo-noreply) est dédié à Forgejo : il doit correspondre à
# MAIL_USER/MAIL_PASSWD dans source-control/forgejo/example.env.
SMTP_USER=noreply@wittnerlab.com:change_me_strong_password forgejo-noreply@wittnerlab.com:change_me_smtp_password

# Email pour les notifications Let's Encrypt (expiration, etc.)
LETSENCRYPT_EMAIL=jeanbaptiste.wittner@outlook.com

# Serveur ACME — laisser vide ou commenter pour utiliser la prod par défaut.
# Staging (pour tests, pas de rate limit strict, certs non valides navigateur) :
#   https://acme-staging-v02.api.letsencrypt.org/directory
# Prod :
#   https://acme-v02.api.letsencrypt.org/directory
LETSENCRYPT_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
