{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "ignorePaths": [
    "archive/**",
    "docs/**",
    "examples/**"
  ],
  "argocd": {
    "managerFilePatterns": ["/\\.app\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["pin", "patch", "minor"],
      "automerge": true
    },
    {
      "matchPackageNames": ["renovate/renovate"],
      "automerge": true
    }
  ]
}
